-- Simulation Relation
def sim_sb (s_mir : mirlite.State) (s_osea : oseair.State) (map : PlaceMap) : Prop :=
  ∀ (base : Word) (reg : Register), (base, reg) ∈ map →
    match s_mir.env.lookup base, s_osea.reg.lookup reg with
    | some (addr, _, _), some (_, [oseair.Val.Ptr b _ _ _]) =>
       match s_mir.ap.StackMap.find? addr, s_osea.ap.StackMap.find? b with
       | some stack1, some stack2 => sb_eq stack1 stack2
       | _, _ => False
    | _, _ => False

def sim_mem (s_mir : mirlite.State) (s_osea : oseair.State) (map : PlaceMap) : Prop :=
  ∀ (base : Word) (reg : Register), (base, reg) ∈ map →
    match s_mir.env.lookup base, s_osea.reg.lookup reg with
    | some (addr, ty, _), some (_, [oseair.Val.Ptr b _ _ _]) =>
       mem_eq s_mir.mem s_osea.mem addr b (mirlite.typeSize ty)
    | _, _ => False

def sim (s_mir : mirlite.State) (s_osea : oseair.State) (map : PlaceMap) : Prop :=
  sim_sb s_mir s_osea map ∧ sim_mem s_mir s_osea map

-- Simplified OSEA-IR execution relation (multi-step)
inductive step_star : oseair.State → oseair.Prog → oseair.State → Prop
| refl (s : oseair.State) : step_star s [] s
| step (s1 s2 s3 : oseair.State) (i : oseair.Instr) (rest : oseair.Prog) :
    oseair.step s1 [i] = oseair.Result.Ok s2 →
    step_star s2 rest s3 →
    step_star s1 (i :: rest) s3

