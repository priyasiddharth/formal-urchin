-- Helpers for equivalence
def sb_eq (stack1 : BorrowStack) (stack2 : BorrowStack) : Prop :=
  stack1 = stack2

def mem_val_eq (v1 : mirlite.MemValue) (v2 : oseair.Val) : Prop :=
  match v1, v2 with
  | mirlite.MemValue.Val n1, oseair.Val.Dat n2 => n1 = n2
